# =============================================================================
# PRODUCTION env template — variables for docker-compose.prod.yml. Domain: app.cmbcore.com
# =============================================================================
# Lives at the REPO ROOT (next to docker-compose.yml). docker-compose.prod.yml uses
# ${VAR} substitution and `docker compose` auto-reads ./.env in this dir for it.
#
#   CLI:       cp .env.example .env && chmod 600 .env       # fill the blanks below
#              docker compose -f docker-compose.prod.yml up -d --build
#              docker compose -f docker-compose.prod.yml exec app php artisan migrate --force
#   Portainer: don't ship a .env — paste these into the stack's "Environment variables" UI.
#
# ./.env is gitignored — NEVER commit it. (Dev/shared config lives in app/.env, which IS
# committed since the repo is private; this prod template uses production-grade values.)
# TLS + host routing for app.cmbcore.com is handled by the external reverse proxy
# (NPM/Caddy on the `proxy` network) -> cmb-web:80.
#
# Anything not listed here is either hard-coded in docker-compose.prod.yml (in-cluster
# hostnames, APP_ENV=production, LOG_STACK=json, SESSION_DRIVER=redis, …) or has a sane
# default in config/. Vars with a "= " value already have a default in the compose file;
# blanks MUST be filled.

# --- Core ---
APP_NAME=OmniSell
# Generate a NEW key for prod — do NOT reuse the dev APP_KEY in app/.env:
#   docker compose -f docker-compose.prod.yml run --rm app php artisan key:generate --show
APP_KEY=
APP_URL=https://app.cmbcore.com
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_TAG=latest                        # container image tag (used in image names)
LOG_LEVEL=info

# --- Cookies / Sanctum (SPA + API share the host app.cmbcore.com) ---
SANCTUM_STATEFUL_DOMAINS=app.cmbcore.com
SESSION_DOMAIN=app.cmbcore.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_LIFETIME=120

# --- Database (PostgreSQL container — only the password belongs here) ---
DB_DATABASE=cmbcoreseller
DB_USERNAME=cmbcoreseller
DB_PASSWORD=                          # REQUIRED — strong password

# --- Object storage (MinIO container — these are also the MinIO root user/pass) ---
AWS_ACCESS_KEY_ID=                    # REQUIRED — strong key
AWS_SECRET_ACCESS_KEY=                # REQUIRED — strong secret
AWS_BUCKET=omnisell
AWS_DEFAULT_REGION=ap-southeast-1

# --- Mail (real SMTP in prod) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS=no-reply@cmbcore.com
MAIL_FROM_NAME=OmniSell

# --- Error monitoring ---
SENTRY_LARAVEL_DSN=

# --- Marketplace integrations ---
INTEGRATIONS_CHANNELS=manual,tiktok
INTEGRATIONS_CARRIERS=

# --- TikTok Shop (PRODUCTION app — not the sandbox creds from app/.env) ---
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_SERVICE_ID=
TIKTOK_SANDBOX=false
