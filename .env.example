# =============================================================================
# PRODUCTION env file template — for docker-compose.prod.yml.
# =============================================================================
# This file lives at the REPO ROOT (next to docker-compose.yml) and is read by
# the prod compose via `env_file: ./.env`. Copy it to `./.env`, fill the blanks,
# `chmod 600 .env`. The real ./.env is gitignored — NEVER commit it. (The DEV
# config lives in app/.env, which IS committed because the repo is private.)
#
#   cp .env.example .env && chmod 600 .env   # then edit
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml exec app php artisan migrate --force
#
# Domain: app.cmbcore.com — TLS + host routing handled by the external reverse
# proxy (NPM/Caddy on the `proxy` network) pointing at  cmb-web:80.

APP_NAME=OmniSell
APP_ENV=production
# Generate a NEW key for prod (do NOT reuse the dev APP_KEY in app/.env):
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml run --rm app php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=https://app.cmbcore.com
APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

# Container image tag (CI build → registry, or local build). `latest` if unset.
APP_TAG=latest

# --- Reverse proxy / cookies (app + API on the same host: app.cmbcore.com) ---
TRUSTED_PROXIES=*
SANCTUM_STATEFUL_DOMAINS=app.cmbcore.com
SESSION_DRIVER=redis
SESSION_DOMAIN=app.cmbcore.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_LIFETIME=120

# --- Logging (containers ship JSON to stdout) ---
LOG_CHANNEL=stack
LOG_STACK=json
LOG_LEVEL=info

# --- Database (PostgreSQL container; host/db/user come from the base compose) ---
# Only the password belongs here — DB_HOST=postgres etc. are set in docker-compose.yml.
DB_PASSWORD=

# --- Cache / Queue (Redis container) ---
CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_PASSWORD=null

# --- Object storage (MinIO container; bucket created by `minio-init`) ---
# Endpoint/region set in docker-compose.yml; set the access key/secret/bucket here.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=omnisell
FILESYSTEM_DISK=s3

# --- Mail (real SMTP in prod) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="no-reply@cmbcore.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Error monitoring ---
SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Marketplace integrations ---
INTEGRATIONS_CHANNELS=manual,tiktok
INTEGRATIONS_CARRIERS=

# --- TikTok Shop (PRODUCTION app, not the sandbox creds from app/.env) ---
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_SERVICE_ID=
TIKTOK_SANDBOX=false
# Override base URLs only if needed:
# TIKTOK_API_BASE_URL=https://open-api.tiktokglobalshop.com
# TIKTOK_AUTH_BASE_URL=https://auth.tiktok-shops.com
# TIKTOK_AUTHORIZE_URL=https://services.tiktokshop.com/open/authorize
