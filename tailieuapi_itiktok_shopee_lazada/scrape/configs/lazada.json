{
  "name": "Lazada Open Platform",
  "startUrls": ["https://open.lazada.com/apps/doc/api?path=%2Fauth%2Ftoken%2Fcreate"],
  "outDir": "../lazada",
  "includePattern": "open\\.lazada\\.com/apps/doc/api\\?path=",
  "excludePattern": "\\.(png|jpg|jpeg|gif|svg|pdf|zip)$",
  "scopeSelector": ".ui-dir-tree",
  "linkSelector": "a[href*='path=']",
  "expandSelectors": [".ui-dir-tree [role='listitem'][aria-expanded='false']"],
  "expandOnce": true,
  "contentSelector": [".api-detail", ".page-home-content", "main"],
  "removeSelectors": ["script", "style", "noscript", "svg"],
  "waitForSelector": ".api-detail",
  "waitMs": 1400,
  "navTimeoutMs": 45000,
  "maxPages": 2500,
  "headless": true
}
