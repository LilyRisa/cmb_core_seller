APP_NAME=CMBcoreSeller
APP_ENV=local
APP_KEY=base64:/F3QPFBjm0K67fOG/JF0rYhjqivFniOE0zaKuUzvrsI=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_DISPLAY_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=https://app.cmbcore.com

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database -----------------------------------------------------------
# Local dev defaults to SQLite (zero setup). The Docker stack and staging/
# prod use PostgreSQL — switch to: DB_CONNECTION=pgsql, host/port/db/user/pass.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cmbcoreseller
DB_USERNAME=cmbcoreseller
DB_PASSWORD=1995oklangtu

# --- Session / Sanctum SPA ----------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Domains the SPA is served from (cookie auth). Add your prod domain.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000,localhost:5173
FRONTEND_URL=http://localhost:8000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@cmbcoreseller.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- Notifications module (SPEC 0022) ---
NOTIFICATIONS_BRAND_NAME=CMBcoreSeller
NOTIFICATIONS_BRAND_TAGLINE="Quản lý bán hàng đa sàn"
NOTIFICATIONS_SUPPORT_EMAIL=support@cmbcore.com
NOTIFICATIONS_PRIMARY_COLOR=#10B981
NOTIFICATIONS_ACCENT_COLOR=#059669

# --- Object storage (S3-compatible: AWS S3 or MinIO) --------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- PDF rendering (Gotenberg) ------------------------------------------
GOTENBERG_URL=http://localhost:3000

# --- Marketplace / carrier integrations ---------------------------------
# Comma-separated provider codes whose connectors are loaded. 'manual' is always on.
INTEGRATIONS_CHANNELS=manual,tiktok
# e.g. ghn,ghtk,jt,viettelpost
INTEGRATIONS_CARRIERS=
INTEGRATIONS_DEFAULT_CARRIER=
# Messaging connectors loaded into MessagingRegistry. 'manual' always on.
# tiktok_chat: tin nhắn CS TikTok về /webhook/tiktok (demux), dùng chung token với orders.
# zalo_oa (SPEC 0039): thêm vào CSV + set MESSAGING_ZALO_APP_ID/APP_SECRET để bật.
# OA_SECRET (ký webhook) optional — trống ⇒ fallback APP_SECRET. REDIRECT_URI optional —
# trống ⇒ tự dựng <APP_URL>/oauth/zalo_oa/callback.
INTEGRATIONS_MESSAGING=tiktok_chat
# MESSAGING_ZALO_APP_ID=
# MESSAGING_ZALO_APP_SECRET=
# MESSAGING_ZALO_OA_SECRET=    # "OA Secret Key" ký webhook (nên KHÁC App Secret); trống ⇒ fallback APP_SECRET
# MESSAGING_ZALO_REDIRECT_URI=   # optional, mặc định = <APP_URL>/oauth/zalo_oa/callback
TIKTOK_APP_KEY=6juf66fn82dqh
TIKTOK_APP_SECRET=5defe803ab6a6066d17a187f4936d51553aca492
TIKTOK_APP_SANDBOX=true
# Ads providers (trục Ads). 'tiktok' = TikTok Marketing API (ADR-0025, read-only).
# Thêm 'facebook' nếu cũng dùng FB Ads. Rỗng = tắt toàn bộ Ads.
INTEGRATIONS_ADS=tiktok
# TikTok Marketing (Ads) — app RIÊNG, KHÁC TIKTOK_APP_KEY (TikTok Shop). Điền creds thật.
TIKTOK_ADS_APP_ID=
TIKTOK_ADS_APP_SECRET=
TIKTOK_ADS_REDIRECT_URI=https://app.cmbcore.com/oauth/tiktok_marketing/redirect
# CAPTCHA (Cloudflare Turnstile) chống bot/brute-force — register/login/forgot. Dev: tắt.
CAPTCHA_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
# SHOPEE_PARTNER_ID=
# SHOPEE_PARTNER_KEY=
# LAZADA_APP_KEY=
# LAZADA_APP_SECRET=

