# Laravel app env — DEV / shared config (this is the template for app/.env, which IS
# committed because the repo is private). For PRODUCTION env see ../.env.example at the
# repo root (used by docker-compose.prod.yml via env_file: ./.env). Domain prod = app.cmbcore.com.
APP_NAME=CMBcoreSeller
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=http://localhost:8000

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database -----------------------------------------------------------
# Local dev defaults to SQLite (zero setup). The Docker stack and staging/
# prod use PostgreSQL — switch to: DB_CONNECTION=pgsql, host/port/db/user/pass.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=cmbcoreseller
# DB_USERNAME=postgres
# DB_PASSWORD=

# --- Session / Sanctum SPA ----------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Domains the SPA is served from (cookie auth). Add your prod domain.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000,localhost:5173
FRONTEND_URL=http://localhost:8000

# CORS (SPEC 0029) — origin cho client cross-origin (Expo Web khi test trên trình duyệt).
# CSV; native Bearer client (Expo iOS/Android) không cần. Dev default = Expo dev server.
CORS_ALLOWED_ORIGINS=http://localhost:8081

# Expo Push (SPEC 0029) — push tin nhắn mới cho app mobile. enabled=false ⇒ tắt toàn bộ.
# EXPO_ACCESS_TOKEN chỉ cần khi bật "Enhanced Security for Push" trên Expo.
EXPO_PUSH_ENABLED=false
EXPO_ACCESS_TOKEN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@cmbcoreseller.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- Notifications module (SPEC 0022) ---
NOTIFICATIONS_BRAND_NAME=CMBcoreSeller
NOTIFICATIONS_BRAND_TAGLINE="Quản lý bán hàng đa sàn"
NOTIFICATIONS_SUPPORT_EMAIL=support@cmbcore.com
NOTIFICATIONS_PRIMARY_COLOR=#10B981
NOTIFICATIONS_ACCENT_COLOR=#059669

# --- Object storage (S3-compatible: AWS S3 or MinIO) --------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Cloudflare R2 (user-uploaded media: SKU/product images) ------------
# Bucket > Settings > S3 API: endpoint = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Token: R2 > "Manage R2 API Tokens" > Object Read & Write, scoped to the bucket.
# R2_URL = the bucket's PUBLIC base URL: the r2.dev URL (enable "Public access")
#          OR (recommended) a custom domain bound to the bucket, e.g. https://cdn.example.com
# See docs/07-ops/cloudflare-r2-uploads.md for the full walk-through.
MEDIA_DISK=public                       # set to "r2" in production
MEDIA_IMAGE_MAX_KB=5120
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=
R2_ENDPOINT=
R2_URL=
R2_USE_PATH_STYLE_ENDPOINT=true

# --- PDF rendering (Gotenberg) ------------------------------------------
GOTENBERG_URL=http://localhost:3000
# Default print-slip paper size (per-tenant override: Cài đặt → Mẫu in). One slip per page.
# Values: A4 | A5 | A6 | 100x150mm | 80mm
PRINT_LABEL_SIZE=A6

# --- Marketplace / carrier integrations ---------------------------------
# Comma-separated provider codes whose connectors are loaded. 'manual' is always on.
# Implemented: tiktok (Phase 1), lazada (Phase 4 — SPEC 0008). shopee = follow-up.
INTEGRATIONS_CHANNELS=manual,tiktok,lazada
# SPEC-0024 (Phase 7.x đề xuất) — Omnichannel Messaging. 'manual' luôn nạp (test/dev).
# S2 sẽ thêm 'facebook_page'; S4 thêm 'tiktok_chat,shopee_chat'; S8 (best-effort) 'lazada_chat'.
INTEGRATIONS_MESSAGING=
# Facebook Page Messenger setup (S2):
MESSAGING_FACEBOOK_VERIFY_TOKEN=
MESSAGING_FACEBOOK_APP_ID=
MESSAGING_FACEBOOK_APP_SECRET=
MESSAGING_FACEBOOK_GRAPH_VERSION=v19.0
# Messaging media (S2/S6): disk + size limits (MB) + signed URL TTL (giây).
# Mặc định theo FILESYSTEM_DISK; production dùng object storage S3-compatible (r2).
MESSAGING_MEDIA_DISK=
MESSAGING_SIGNED_URL_TTL=300
MESSAGING_MAX_IMAGE_MB=25
MESSAGING_MAX_VIDEO_MB=100
MESSAGING_MAX_FILE_MB=25
# Carriers (Phase 3 / SPEC 0006). 'manual' is ALWAYS available; list extra ones here.
# Currently implemented: ghn. (ghtk, jt, ... are follow-ups.) Carrier API credentials
# are entered per tenant in the UI (Cài đặt → ĐVVC), not via env.
INTEGRATIONS_CARRIERS=
INTEGRATIONS_DEFAULT_CARRIER=
GHN_BASE_URL=https://online-gateway.ghn.vn
# GHTK base URL (staging = https://services-staging.ghtklab.com). Credentials (token + client_source) per tài khoản ĐVVC.
GHTK_BASE_URL=https://services.giaohangtietkiem.vn
# Fulfillment (Phase 3): when stock leaves ('shipped' = on handover/scan-to-pack; 'created' = on shipment create)
FULFILLMENT_DEDUCT_ON=shipped
FULFILLMENT_DEFAULT_WEIGHT_GRAMS=500
# "Luồng A" — "Chuẩn bị hàng" gọi API sàn arrange-shipment (đẩy trạng thái "đã in đơn") + lấy tem thật.
# Bật mặc định (endpoint TikTok đối chiếu theo SDK chính thức fulfillment 202309). Đặt =false nếu shop yêu cầu
# cấu hình handover_method khác / lỗi gọi sàn (lỗi vẫn được bắt & gắn cờ has_issue trên đơn, không chặn).
INTEGRATIONS_TIKTOK_FULFILLMENT=true
# (tuỳ chọn) Ghi đè đường dẫn endpoint fulfillment TikTok nếu cần:
# TIKTOK_SHIP_PACKAGE_PATH=/fulfillment/{version}/packages/{package_id}/ship
# TIKTOK_PACKAGE_DETAIL_PATH=/fulfillment/{version}/packages/{package_id}
# TIKTOK_SHIPPING_DOCS_PATH=/fulfillment/{version}/packages/{package_id}/shipping_documents

# --- TikTok Shop (Phase 1) — SANDBOX ------------------------------------
# Create a test app + test seller in TikTok Shop Partner Center, then put the
# SANDBOX app_key / app_secret / service_id here. Keep TIKTOK_SANDBOX=true.
# All TikTok URLs/versions/maps live in config/integrations.php (nothing hard-coded).
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_SERVICE_ID=
TIKTOK_SANDBOX=true
# Override base URLs only if Partner Center gives you sandbox-specific hosts:
# TIKTOK_API_BASE_URL=https://open-api.tiktokglobalshop.com
# TIKTOK_AUTH_BASE_URL=https://auth.tiktok-shops.com
# TIKTOK_AUTHORIZE_URL=https://services.tiktokshop.com/open/authorize

# --- Lazada Open Platform (Phase 4 / SPEC 0008) — SANDBOX ---------------
# Create a sandbox app + test seller in the Lazada Open Platform, put the SANDBOX
# app key/secret here, and register the callback URL in the app console as exactly
#   https://<APP_URL host>/oauth/lazada/callback
# All Lazada URLs/maps live in config/integrations.php (nothing hard-coded).
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
LAZADA_SANDBOX=true
# LAZADA_REDIRECT_URI=          # defaults to <APP_URL>/oauth/lazada/callback
# Override only if your account/sandbox uses different hosts:
# LAZADA_API_BASE_URL=https://api.lazada.vn/rest
# LAZADA_AUTH_BASE_URL=https://auth.lazada.com/rest
# LAZADA_AUTHORIZE_URL=https://auth.lazada.com/oauth/authorize

# --- Shopee Open Platform (Phase 4) — build faithful theo docs; verify sandbox trước khi thêm vào INTEGRATIONS_CHANNELS
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
# Push Partner Key RIÊNG (Shopee Push Mechanism) verify webhook push; trống ⇒ fallback PARTNER_KEY.
SHOPEE_PUSH_PARTNER_KEY=
SHOPEE_SANDBOX=true
# SHOPEE_API_BASE_URL=https://partner.shopeemobile.com   # sandbox VN/Global: https://openplatform.sandbox.test-stable.shopee.sg
# SHOPEE_REDIRECT_URI=    # default url('/oauth/shopee/callback')
# SHOPEE_PUSH_URL=        # default url('/webhook/shopee') — dùng để verify chữ ký push
# INTEGRATIONS_SHOPEE_FULFILLMENT=true
# INTEGRATIONS_SHOPEE_FINANCE=false

# --- Error monitoring ---------------------------------------------------
# SENTRY_LARAVEL_DSN=

VITE_APP_NAME="${APP_NAME}"
