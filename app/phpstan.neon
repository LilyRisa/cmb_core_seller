includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    # Starting level for Phase 0. Raise it deliberately as the codebase grows
    # (see docs/07-infra/ci-cd-pipeline.md §5) — do not lower it to make CI pass.
    # phpstan-baseline.neon holds the pre-existing findings to burn down over time;
    # new code must not add to the baseline.
    level: 5

    paths:
        - app

    bootstrapFiles:
        - vendor/autoload.php
